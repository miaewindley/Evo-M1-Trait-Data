library(ggplot2)
library(caper)
library(dplyr)
# Load the data
MammalData <- read.csv("gyz043_suppl_Supplement_Data.csv")
# # Load the  TimeTree tree
# MammalTree <- read.tree("species.nwk")
# Load the Burger tree
MammalTree <- read.nexus("SFritz.tre")
# View the Burger tree as Newick
newick <- write.tree(MammalTree)
print(newick)
# Define the PGLS model lambda = "ML"
model.pgls <- pgls(log10(Mean_brain_mass_g) ~ log10(Mean_body_mass_g), data = MammalOrder, lambda = "ML")
# Create the comparative data object
MammalOrder <- comparative.data(phy = MammalTree, data = MammalData, names.col = Binomial, vcv = TRUE, na.omit = FALSE, warn.dropped = TRUE)
# Define the PGLS model lambda = "ML"
model.pgls <- pgls(log10(Mean_brain_mass_g) ~ log10(Mean_body_mass_g), data = MammalOrder, lambda = "ML")
plot(res)
# Print the summary of the PGLS model
print(summary(model.pgls))
# Get residual values
residuals <- residuals(model.pgls)
print(residuals)
# To identify the outliers in a PGLS model, first you need to extract the phylogenetic residuals from the model:
res<- residuals(model.pgls, phylo = TRUE) #extracts phylogenetic residuals from the pgls model
# Next these residuals need to be standardized by dividing by their square root of their variance:
res<- res/sqrt(var(res))[1] #standardises residuals by sqrt of their variance
# Finally the residuals can be matched to the species names and the outlier idenitified (in this case Colobus_polykomos):
rownames(res)<-rownames(model.pgls$residuals) #matches the residuals up with the species names
rownames(res)[(abs(res)>3)]#gives the names of the outliers
# Get residual values
print(model.pgls$residuals)
# Get stand res values
res<- residuals(model.pgls, phylo = TRUE) #extracts phylogenetic residuals from the pgls model
res<- res/sqrt(var(res))[1] #standardises residuals by sqrt of their variance
rownames(res)<-rownames(model.pgls$residuals) #matches the residuals up with the species names
print(res)
plot(res)
View(residuals)
View(res)
View(residuals)
View(residuals)
View(res)
#calculate studentized residuals
stud_resids <- studres(model.pgls)
# Get root mean square error for linear model
rmse<- residuals(model.pgls, phylo = TRUE) #extracts phylogenetic residuals from the pgls model
rrmse<- sqrt(mean(residuals^2)) #standardises residuals by sqrt of their variance
rownames(rmse)<-rownames(model.pgls$residuals) #matches the residuals up with the species names
print(rmse)
View(rmse)
