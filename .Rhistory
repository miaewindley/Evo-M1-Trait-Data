new_df$abc->abc
# check the order of your data: best if data vectors
# are sorted in the same order of the species on the phylogeny
abc[match(tree1$tip.label,names(abc))]->abc
library(RRphylo)
# Do the calculation
RR <- RRphylo(tree=tree1,y=abc)
