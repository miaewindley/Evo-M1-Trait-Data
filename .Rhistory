title(main = "ANCESTRAL TRAIT RECONSTRUCTION residuals_EI_ratio.logBrainmass", cex.main = .5)
plot(EI_ratio ~ log(brain_mass), data = merged_df)
text(log(merged_df$brain_mass), merged_df$EI_ratio,
labels = as.character(merged_df$Species), pos = 3)
