setwd("~/Library/CloudStorage/OneDrive-AllenInstitute/Analysis-Evo-M1-Trait")
library(tidyverse)
library(dplyr)
library(tidyr)
library(plotrix) # For plotting ancestral states
library(readxl)
library(openxlsx) # For writing to xl
library(rphylopic) # For phylopic
library(ggplot2)
library(geiger)
library(caper) # For phylogenetic tree
library(ape) # For phylogenetic tree manipulation
library(phytools)  # For phylogenetic analysis
library(phylolm) # For phylogenetic tree and K
library(RRphylo) # For rates of evolution
library(RColorBrewer) # For color palette
meta_m1 <- read_csv(file = "~/Library/CloudStorage/OneDrive-AllenInstitute/Data/combined_metadata.csv")
colnames(meta_m1)[colnames(meta_m1) == "organism_species"] <- "Species"
colnames(meta_m1)[colnames(meta_m1) == "consensus_class_label"] <- "class"
colnames(meta_m1)[colnames(meta_m1) == "consensus_subclass_label"] <- "predicted.id"
meta_m1$class = sub("GABAergic", "Inhibitory", meta_m1$class)
meta_m1$class = sub("Glutamatergic", "Excitatory", meta_m1$class)
meta_m1$class = sub("Non-Neuronal", "Non-neuronal", meta_m1$class)
meta_m1$Species = sub("Saimiri sciureus", "Saimiri boliviensis boliviensis", meta_m1$Species)
meta_m1$Species = sub("Gorilla gorilla", "Gorilla gorilla gorilla", meta_m1$Species)
# table class proportions - donor_id
meta_m1_donor_id <-
meta_m1 %>%
group_by(Species, donor_id, class) %>%
count() %>%
print(meta_m1_donor_id)
# Calculate the ratio between Excitatory and Inhibitory cells - donor_id
EI_ratios_donor_id <- meta_m1_donor_id %>%
group_by(Species, donor_id) %>%
summarize(EI_ratio = sum(n[class == "Excitatory"]) / sum(n[class == "Inhibitory"]))
# Create the boxplot
boxplot <- ggplot(data = EI_ratios_donor_id, aes(x = Species, y = EI_ratio)) +
geom_boxplot(fill = "lightblue", color = "blue") +
geom_point(aes(color = donor_id), size = 2) +
labs(x = "Species", y = "E:I Ratio") +
theme_minimal() +
theme(axis.text.x = element_text(face = "italic", size = 8, angle = 90, hjust = 1))
# Add title and text annotation
boxplot <- boxplot +
ggtitle("E:I Ratio by Species and Donor ID") +
annotate("text", x = 5, y = max(EI_ratios_donor_id$EI_ratio) + -1,
label = "Boxes represent interquartile range (IQR).\n Whiskers extend up to 1.5 times the IQR, based on Tukey's fences. \n Data points beyond the whiskers are considered outliers.",
hjust = 0.5, size = 3)  # Set vjust to 0 for bottom alignment
# Remove the legend
boxplot <- boxplot +
guides(fill = "none", color = "none")
# Save as PDF
ggsave("boxplot.pdf", plot = boxplot, width = 8, height = 6, units = "in", dpi = 300)
# Display the plot
print(boxplot)
# table subclass proportions
pdf("meta_m1.pdf")
meta_m1 %>%
group_by(Species, class, predicted.id) %>%
count() %>%
group_by(Species, class) %>%
mutate(prop = n/sum(n),
group = ifelse(class == "Excitatory", 1,
ifelse(class == "Inhibitory", 2,
ifelse(class == "Non-neuronal", 3, NA)))) %>%
ggplot(aes(x = factor(predicted.id, levels = unique(predicted.id)[order(group)]), y = Species, color = class, size = prop)) +
geom_point() +
theme(axis.text.x = element_text(angle=90, vjust=.5, hjust=1)) +
xlab("Predicted ID")
