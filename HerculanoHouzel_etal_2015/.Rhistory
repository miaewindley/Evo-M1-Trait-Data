desired_text <- page_text[desired_lines]
# Now, you can further process the 'desired_text' to extract the specific data you need.
desired_text
desired_lines
# Load the required library
library(tabulizer)
# Define the PDF file path
pdf_file <- "Herculano-Houze-2015-Mammalian Brains Are Made.pdf"
# Specify the page number
page_number <- 5
# Use extract_text to get the raw text from page 5
page_text <- extract_text(pdf_file, pages = page_number)
# Split the text into lines
lines <- strsplit(page_text, "\n")
# Get the last few lines (adjust the number as needed)
num_lines_to_extract <- 10  # Change this to the number of lines you want to extract from the end
desired_text <- tail(lines[[1]], num_lines_to_extract)
# Convert the extracted text back to a single string
desired_text <- paste(desired_text, collapse = "\n")
# Now, 'desired_text' contains the text from the very end of the page
cat(desired_text)
