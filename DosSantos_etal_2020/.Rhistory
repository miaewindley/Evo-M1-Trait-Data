# Define the URL of the ZIP file
zip_url <- "https://oup.silverchair-cdn.com/oup/backfile/Content_public/Journal/jmammal/100/2/10.1093_jmammal_gyz043/1/gyz043_suppl_supplement_data.zip"
# Define the name of the CSV file within the ZIP archive
csv_filename <- "your_csv_filename.csv"  # Replace with the actual filename
# Download the ZIP file
zip_response <- GET(zip_url, write_disk(tempfile(fileext = ".zip")))
# Check if the download was successful
if (http_type(zip_response) == "application/zip") {
# Open the ZIP file
zip_file <- unzip(zip_response$content, exdir = tempdir())
# Read the CSV file from the ZIP archive
data <- read.csv(file.path(tempdir(), csv_filename))
# Now, 'data' contains your CSV data
head(data)  # View the first few rows of the CSV data
} else {
cat("Failed to download the ZIP file.")
}
