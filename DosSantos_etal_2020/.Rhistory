# Get rid of all empty columns that were automatically named "V..."
# Define a function to check if a column has a header starting with "V" and no data
is_empty_V_column <- function(column) {
starts_with_V <- grepl("^V", colnames(column))
is_empty <- all(is.na(column))
return(starts_with_V && is_empty)
}
# Remove columns with headers starting with "V" and no data
df1 <- df1[, !sapply(df1, is_empty_V_column)]
df2 <- df2[, !sapply(df2, is_empty_V_column)]
df3 <- df3[, !sapply(df3, is_empty_V_column)]
# Get rid of all empty columns that were automatically named "V..."
# Define a function to check if a column has a header starting with "V" and no data
is_empty_V_column <- function(column) {
starts_with_V <- grepl("^V//", colnames(column))
is_empty <- all(is.na(column))
return(starts_with_V && is_empty)
}
# Remove columns with headers starting with "V" and no data
df1 <- df1[, !sapply(df1, is_empty_V_column)]
df2 <- df2[, !sapply(df2, is_empty_V_column)]
df3 <- df3[, !sapply(df3, is_empty_V_column)]
