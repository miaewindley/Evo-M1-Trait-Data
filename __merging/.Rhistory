# Keep only rows that are duplicated based on the "Variable" column
Tragelaphus_strepsiceros_data <- Tragelaphus_strepsiceros_data %>%
filter(duplicated(Variable) | duplicated(Variable, fromLast = TRUE))
# Assuming "Tragelaphus_strepsiceros_data" is your filtered dataset
Tragelaphus_strepsiceros_data <- Tragelaphus_strepsiceros_data %>%
group_by(Variable) %>%
filter(n_distinct(Value) > 1)
# Assuming "Tragelaphus_strepsiceros_data" is your filtered dataset
percent_difference <- Tragelaphus_strepsiceros_data %>%
group_by(Variable) %>%
summarise(percent_difference = ((max(Value) - min(Value)) / ((max(Value) + min(Value)) / 2)) * 100)
