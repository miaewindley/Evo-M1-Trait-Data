Source %in% c("DosSantos_etal_2020_Table1", "HerculanoHouzel_etal_2015_Table5"),
Variable == "WholeBrain_C.n") %>%
mutate_at(vars(starts_with("DosSantos_etal_2020") | starts_with("HerculanoHouzel_etal_2015")),
as.numeric) %>%
group_by(Species, Variable) %>%
summarise(Difference = max(ifelse(Source == "DosSantos_etal_2020_Table1", Value, 0)) -
max(ifelse(Source == "HerculanoHouzel_etal_2015_Table5", Value, 0)))
