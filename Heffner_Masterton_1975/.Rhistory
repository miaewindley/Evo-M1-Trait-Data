# Function to clean Species based on provided conditions
clean_species_name <- function(name) {
# Remove terms "days" or "gestation", numerals, symbols . : ;, and replace underscores with spaces
cleaned_name <- gsub("days|gestation|\\d+|[.;:]", "", name, ignore.case = TRUE)
cleaned_name <- gsub("_", " ", cleaned_name)
# Remove leading and trailing whitespaces
cleaned_name <- trimws(cleaned_name)
return(cleaned_name)
}
# Fill in the "Species" values for columns numbered in number_columns
for (column_number in number_columns) {
# Get the value from Row 2
