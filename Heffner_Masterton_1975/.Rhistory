if (!is.na(prefix) && !is.na(suffix) && nchar(prefix) > 0) {
## Replace spaces with underscores in the prefix
prefix <- gsub(" ", "_", prefix)
col_name <- ifelse(nchar(suffix) > 0, paste(prefix, suffix, sep = ""), prefix)
## Assign the new column name
colnames(translating_time_dataset)[col] <- col_name
}
}
