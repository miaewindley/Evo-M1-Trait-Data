# summer_rownames$Total_neocortex_check <- rowSums(summer_rownames[,total_neo_rows])
# Calculate 'Total_neocortex_check' and 'Total_neocortex_diff'
summer_rownames <- summer_rownames %>%
mutate(
Total_neocortex_check = rowSums(select(., all_of(existing_columns)), na.rm = TRUE),
Total_neocortex_diff = Total_neocortex - Total_neocortex_check
)
summer_rownames[existing_columns] <- lapply(summer_rownames[existing_columns], function(x) {
suppressWarnings(as.numeric(as.character(x)))
})
# 4. Compare 'Total_neocortex' with 'Total_neocortex_check'
summer_rownames$Total_neocortex_diff <- summer_rownames$Total_neocortex - summer_rownames$Total_neocortex_check
# Move 'Species' to row names and drop 'Total_neocortex' from calculation
summer_rownames <- summer
# List of columns to sum
total_neo_rows <- c("V1", "V2", "MT", "DM", "DL", "FST", "MST...8", "VPP", "VP",
"CT", "Vr", "A1", "R", "A1+R", "S1/3b", "SII", "3a", "PV", "1", "2",
"SII+PV", "M1", "FEF", "FV", "SMA", "FR", "MST...28")
# Ensure all specified columns exist
existing_columns <- intersect(total_neo_rows, names(summer))
# Calculate 'Total_neocortex_check' and 'Total_neocortex_diff'
summer_rownames <- summer_rownames %>%
mutate(
Total_neocortex_check = rowSums(select(., all_of(existing_columns)), na.rm = TRUE),
Total_neocortex_diff = Total_neocortex - Total_neocortex_check
)
