library(compare)
library(dplyr)
# Compare datasets
comparison <- compare(rachael, summer_noneo)
# Extract overall result
identical_result <- isTRUE(comparison)
# Create a data frame
comparison_df <- data.frame(Datasets = c("rachael", "summer_noneo"), Identical = identical_result)
# Print the comparison data frame
print(comparison_df)
# Function to compare values between two data frames
compare_values <- function(df1, df2) {
identical_values <- sapply(1:nrow(df1), function(i) {
sapply(1:ncol(df1), function(j) {
identical(df1[i, j], df2[i, j])
})
})
return(identical_values)
}
# Compare values between rachael and summer_noneo
comparison_values <- compare_values(rachael, summer_noneo)
# Convert comparison values to data frame
comparison_df <- as.data.frame(comparison_values)
# Print the comparison data frame
print(comparison_df)
