# Main dataset
translating_time_dataset <- read_xlsx("Output/Translating_Time_Wide.xlsx", col_names = TRUE, col_types = "text")
archive_distinct_timepoints_001<-read_xlsx("./Appendices/archive_distinct_timepoints_001.xlsx")
# Load the dataset and get the highest number from the Code column
last_max <- translating_time_dataset
# Ensure the Code column is numeric, and suppress warnings for non-convertible values
last_max$Code <- as.numeric(as.character(last_max$Code))
# Get the highest number, ensuring NA values are removed. When using it, enter manually so numbers never change!
maxcode_last_max<-max(last_max$Code, na.rm = TRUE)
maxcode_last_max
# Get the names of columns with timepoint info
timepoint_cols <- colnames(translating_time_dataset)[
which(colnames(translating_time_dataset) == "Code"):
which(colnames(translating_time_dataset) == "Event_category.Environment")]
# Extract the relevant columns from translating_time_dataset based on timepoint_cols
timepoint_data <- translating_time_dataset[, timepoint_cols]
# Get the names of columns with species values
species_value_cols <- colnames(translating_time_dataset)[
which(colnames(translating_time_dataset) == "Vicugna_pacos.Value"):
which(colnames(translating_time_dataset) == "Ovis_aries.Environment")]
# Find the row indices where the column Code contains the value "Species"
species_row <- which(translating_time_dataset$Code == "Species")
# Initialize an empty list to store dataframes for each species
species_dataframes <- list()
# Iterate over each column name in species_value_cols
for (col in species_value_cols) {
# Extract the column from translating_time_dataset.
species_column <- translating_time_dataset[[col]]
# Extract the species name from species_column by referring to species_row
species_name <- species_column[species_row]
# Start a species_group dataframe with the species_column as its first species column
species_group <- as.data.frame(translating_time_dataset[, col, drop = FALSE])
# Rename the first column to retain its original name
colnames(species_group)[1] <- col
# Iterate over each column name in species_value_cols again to find other columns belonging to the same species
for (next_col in species_value_cols) {
# Check if the next_col belongs to the same species and it's not the same as the current column
if (species_name %in% translating_time_dataset[[next_col]][species_row] && next_col != col) {
# Add the next_col to the species_group dataframe
species_group[[next_col]] <- translating_time_dataset[[next_col]]
}
}
# Combine timepoint_data and species_group column-wise
species_dataframes[[species_name]] <- cbind(timepoint_data, species_group)
}
# Print the names of dataframes for each species
print(names(species_dataframes))
# Iterate over each species group dataframe in species_dataframes
for (species_name in names(species_dataframes)) {
# Get the species_group dataframe
species_group <- species_dataframes[[species_name]]
# Create a new column called "Species" with the species name
species_group$Species <- species_name
# Get the name of the last column from timepoint_cols
last_timepoint_col_name <- timepoint_cols[max(match(timepoint_cols, colnames(species_group)))]
# Rearrange columns to move "Species" after last_timepoint_col_index
combined_df <- species_group %>%
select(-Species, everything()) %>%  # Exclude "Species" column and select all other columns
mutate(Species = species_group$Species) %>%  # Add "Species" column back
relocate(Species, .after = all_of(last_timepoint_col_name))  # Move "Species" column to desired position
# Update the species_group dataframe in species_dataframes with the rearranged dataframe
species_dataframes[[species_name]] <- combined_df
}
# Iterate over each species group dataframe in species_dataframes
for (species_name in names(species_dataframes)) {
# Get the species_group dataframe
species_group <- species_dataframes[[species_name]]
# Get the column names after "Species" that are not NA
num_cols_after_species <- ncol(species_group) - which(colnames(species_group) == "Species")
colnames_to_replace <- colnames(species_group)[which(colnames(species_group) == "Species") + 1:num_cols_after_species]
# Replace column names with values from the first row
new_colnames <- c(colnames(species_group)[1:which(colnames(species_group) == "Species")],
as.character(species_group[1, colnames_to_replace]))
# Set new column names to the species_group dataframe
colnames(species_group) <- new_colnames
# Delete the first and second rows
species_group <- species_group %>%
slice(-1:-2)
# Update the species_group dataframe in species_dataframes with the modified dataframe
species_dataframes[[species_name]] <- species_group
}
